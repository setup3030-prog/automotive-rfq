# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (default — no setup needed for local dev):
DATABASE_URL=sqlite:///./rfq.db

# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/rfq_db

# ─── AI Competitor Price Estimation — Google Gemini ──────────────────────────
# Required for the "Estimate with AI" button in the Competitiveness tab.
# Get a free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the Gemini model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.0-flash

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Defaults to http://localhost:5173 when not set.
# ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173
